# FontaineRTC environment — copy to .env and adjust.

# Role: node | admin
FONTAINE_ROLE=node

# Network
FONTAINE_PANEL_HOST=0.0.0.0
FONTAINE_PANEL_PORT=8080
FONTAINE_DATA_DIR=./data

# Auth (leave empty on first run to auto-generate; printed once at startup)
FONTAINE_PANEL_PASSWORD=
FONTAINE_API_KEY=

# --- node role ---
FONTAINE_BINARY_PATH=./olcrtc-linux-amd64
FONTAINE_FFMPEG=ffmpeg
FONTAINE_DNS=1.1.1.1:53
FONTAINE_DEBUG=true
FONTAINE_FULL_LOGS=false
FONTAINE_PUSH_URL=

# --- admin role ---
FONTAINE_POLL_INTERVAL=30
FONTAINE_PANEL_URL=
FONTAINE_TG_BOT_TOKEN=
FONTAINE_TG_RECIPIENTS=
